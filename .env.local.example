# Database (Neon / Supabase / local PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/hatraabeklik"

# Google AI — Gemini Flash 2.5 (תמלול + חילוץ)
GOOGLE_AI_API_KEY="your_google_ai_key_here"

# Anthropic — Claude Sonnet (כתיבת מכתב)
ANTHROPIC_API_KEY="your_anthropic_key_here"

# Site URL (לOG tags)
NEXT_PUBLIC_SITE_URL="https://hatraa.co.il"

# Admin — גישה ל-/database ו-/api/leads
ADMIN_SECRET="change-me-to-a-long-random-secret"

# PII encryption — AES-256 key (מחרוזת ארוכה; נגזרת ל-32 בתים ב-SHA-256)
ENCRYPTION_KEY="change-me-to-a-long-random-encryption-key"

# עו״ד לחבילת חתימה / מכתב מאומת (placeholders — קל לעדכן ב-Vercel env)
NEXT_PUBLIC_ATTORNEY_DISPLAY_NAME="עו״ד [שם להשלמה]"
NEXT_PUBLIC_ATTORNEY_OFFICE_NAME="[שם משרד להשלמה]"
NEXT_PUBLIC_ATTORNEY_LICENSE=""
NEXT_PUBLIC_ATTORNEY_SIGNATURE_CAPTION="מאומת ומאושר"
NEXT_PUBLIC_ATTORNEY_PHONE=""
NEXT_PUBLIC_ATTORNEY_EMAIL=""
NEXT_PUBLIC_ATTORNEY_ADDRESS=""

# Cloudflare R2 — ראיות/נספחים (bucket פרטי + signed URLs)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="hatraa-evidence"
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
