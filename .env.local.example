# Database (Neon / Supabase / local PostgreSQL)
# Neon: הוסף sslmode=verify-full (או השאר require — הקוד ינרמל אוטומטית)
DATABASE_URL="postgresql://user:password@localhost:5432/hatraabeklik?sslmode=verify-full"

# Google AI — Gemini 3.5 Flash (תמלול, חילוץ ושכתוב עו"ד)
GOOGLE_AI_API_KEY="your_google_ai_key_here"

# Anthropic — Claude Sonnet 5 (כתיבת מכתב)
ANTHROPIC_API_KEY="your_anthropic_key_here"

# שער גיבוי רק אם שירות שערי המטבע אינו זמין ואין שער שמור במסד
USD_ILS_FALLBACK_RATE="3.60"

# Site URL (לOG tags)
NEXT_PUBLIC_SITE_URL="https://hatraa.co.il"

# פרטי עוסק / משפטי (placeholders — להשלים לפני עלייה לאוויר)
NEXT_PUBLIC_BRAND_NAME="התראה בקליק"
NEXT_PUBLIC_BUSINESS_LEGAL_NAME="[שם העסק / החברה להשלמה]"
NEXT_PUBLIC_BUSINESS_REGISTRATION_TYPE="עוסק מורשה / חברה בע״מ"
NEXT_PUBLIC_BUSINESS_REGISTRATION_NUMBER="[מספר עוסק / ח.פ. להשלמה]"
NEXT_PUBLIC_BUSINESS_ADDRESS="[כתובת העסק להשלמה]"
NEXT_PUBLIC_BUSINESS_PHONE="[טלפון להשלמה]"
NEXT_PUBLIC_BUSINESS_EMAIL="[דוא״ל ליצירת קשר להשלמה]"
NEXT_PUBLIC_PRIVACY_EMAIL="[דוא״ל פרטיות להשלמה]"
NEXT_PUBLIC_ACCESSIBILITY_COORDINATOR_NAME="[שם רכז/ת נגישות להשלמה]"
NEXT_PUBLIC_ACCESSIBILITY_EMAIL="[דוא״ל נגישות להשלמה]"
NEXT_PUBLIC_ACCESSIBILITY_PHONE="[טלפון נגישות להשלמה]"
NEXT_PUBLIC_LEGAL_LAST_UPDATED="יולי 2026"

# Admin — גישה ל-/admin ולממשקי הניהול
ADMIN_SECRET="change-me-to-a-long-random-secret"

# PII encryption — AES-256 key (מחרוזת ארוכה; נגזרת ל-32 בתים ב-SHA-256)
ENCRYPTION_KEY="change-me-to-a-long-random-encryption-key"

# עו״ד לחבילת חתימה / מכתב מאומת (placeholders — קל לעדכן ב-Vercel env)
NEXT_PUBLIC_ATTORNEY_DISPLAY_NAME="עו״ד [שם להשלמה]"
NEXT_PUBLIC_ATTORNEY_OFFICE_NAME="[שם משרד להשלמה]"
NEXT_PUBLIC_ATTORNEY_LICENSE=""
NEXT_PUBLIC_ATTORNEY_SIGNATURE_CAPTION="מאומת ומאושר"
NEXT_PUBLIC_ATTORNEY_PHONE=""
NEXT_PUBLIC_ATTORNEY_EMAIL=""
NEXT_PUBLIC_ATTORNEY_ADDRESS=""

# Cloudflare R2 — ראיות/נספחים (bucket פרטי + signed URLs)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="hatraa-evidence"
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"

# Inngest — תור משימות לעיבוד מתמשך ברקע
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
# בפיתוח מקומי עם `npx inngest-cli@latest dev`: INNGEST_DEV="http://localhost:8288"
