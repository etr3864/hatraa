generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  idNumber  String?
  address   String
  phone     String
  email     String
  createdAt DateTime @default(now())

  letter   Letter?
  payment  Payment?
  evidence Evidence[]
}

model Letter {
  id                String   @id @default(uuid())
  leadId            String   @unique
  lead              Lead     @relation(fields: [leadId], references: [id])

  category          String
  rawInput          String
  extractedData     Json

  respondentName    String
  respondentAddress String?
  eventDate         String?
  amount            String?

  tone              String
  goal              String

  content           String
  upsellMessage     String
  fileName          String

  knowledgeVersion  String?
  promptSnapshot    String?
  modelResponse     String?
  verified          Boolean  @default(false)

  createdAt         DateTime @default(now())
}

model Payment {
  id        String    @id @default(uuid())
  leadId    String    @unique
  lead      Lead      @relation(fields: [leadId], references: [id])

  amount    Int
  status    String
  paidAt    DateTime?

  createdAt DateTime  @default(now())
}

model Evidence {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  label       String
  fileName    String
  mimeType    String
  sizeBytes   Int
  r2Key       String
  description String?
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())

  @@index([leadId])
}
