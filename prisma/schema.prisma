generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AnalyticsEventType {
  SITE_VISIT
  WIZARD_STARTED
  EXTRACTION_COMPLETED
  DETAILS_COMPLETED
  LETTER_GENERATED
  PAYMENT_STARTED
  PAYMENT_COMPLETED
  ATTORNEY_REWRITE_COMPLETED
  PDF_DOWNLOADED
}

enum AiProvider {
  GOOGLE
  ANTHROPIC
}

enum AiOperation {
  TRANSCRIPTION
  EXTRACTION
  LETTER_GENERATION
  CITATION_RETRY
  GUARDRAIL_RETRY
  ATTORNEY_REWRITE
  ATTORNEY_REWRITE_RETRY
}

enum AiCallStatus {
  SUCCEEDED
  FAILED
}

enum ProcessingJobType {
  EXTRACTION
  LETTER_GENERATION
  ATTORNEY_REWRITE
}

enum ProcessingJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

model Lead {
  id                 String            @id @default(uuid())
  name               String
  idNumber           String?
  address            String
  phone              String
  email              String
  analyticsSessionId String?
  analyticsSession   AnalyticsSession? @relation(fields: [analyticsSessionId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())

  letter          Letter?
  payment         Payment?
  evidence        Evidence[]
  analyticsEvents AnalyticsEvent[]
  aiCalls         AiCallLog[]
  processingJobs  ProcessingJob[]

  @@index([createdAt])
  @@index([analyticsSessionId])
}

model Letter {
  id                String   @id @default(uuid())
  leadId            String   @unique
  lead              Lead     @relation(fields: [leadId], references: [id])

  category          String
  rawInput          String
  extractedData     Json

  respondentName    String
  respondentAddress String?
  eventDate         String?
  amount            String?

  tone              String
  goal              String

  content           String
  upsellMessage     String
  fileName          String

  knowledgeVersion  String?
  promptSnapshot    String?
  modelResponse     String?
  verified          Boolean  @default(false)

  createdAt         DateTime @default(now())

  @@index([category, createdAt])
}

model Payment {
  id        String    @id @default(uuid())
  leadId    String    @unique
  lead      Lead      @relation(fields: [leadId], references: [id])

  amount    Int
  status    String
  paidAt    DateTime?

  createdAt DateTime  @default(now())

  @@index([status, paidAt])
}

model Evidence {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  label       String
  fileName    String
  mimeType    String
  sizeBytes   Int
  r2Key       String   @unique
  description String?
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())

  @@index([leadId])
}

model AnalyticsSession {
  id             String   @id @default(uuid())
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  deviceType     String?
  inputMode      String?
  hasEvidence    Boolean?
  senderType     String?
  category       String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?

  events  AnalyticsEvent[]
  aiCalls AiCallLog[]
  leads   Lead[]
  jobs    ProcessingJob[]

  @@index([firstSeenAt])
  @@index([category, firstSeenAt])
  @@index([deviceType, firstSeenAt])
}

model AnalyticsEvent {
  id             String             @id @default(uuid())
  sessionId      String
  session        AnalyticsSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  type           AnalyticsEventType
  idempotencyKey String             @unique
  metadata       Json?
  occurredAt     DateTime           @default(now())

  @@index([type, occurredAt])
  @@index([sessionId, type])
  @@index([leadId, type])
  @@index([occurredAt])
}

model AiCallLog {
  id                       String            @id @default(uuid())
  requestId                String            @unique
  workflowId               String?
  sessionId                String?
  session                  AnalyticsSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  leadId                   String?
  lead                     Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  provider                 AiProvider
  model                    String
  operation                AiOperation
  status                   AiCallStatus
  inputTokens              Int               @default(0)
  outputTokens             Int               @default(0)
  cachedInputTokens        Int               @default(0)
  thinkingTokens           Int               @default(0)
  inputUsdPerMillion       Decimal           @db.Decimal(12, 6)
  outputUsdPerMillion      Decimal           @db.Decimal(12, 6)
  usdIlsRate               Decimal           @db.Decimal(12, 6)
  costUsd                  Decimal           @db.Decimal(18, 8)
  costIls                  Decimal           @db.Decimal(18, 8)
  latencyMs                Int?
  errorCode                String?
  createdAt                DateTime          @default(now())

  @@index([model, createdAt])
  @@index([operation, createdAt])
  @@index([leadId])
  @@index([workflowId])
  @@index([createdAt])
}

model AiModelPrice {
  id                  String     @id @default(uuid())
  provider            AiProvider
  model               String
  inputUsdPerMillion  Decimal    @db.Decimal(12, 6)
  outputUsdPerMillion Decimal    @db.Decimal(12, 6)
  effectiveFrom       DateTime
  createdAt           DateTime   @default(now())

  @@unique([provider, model, effectiveFrom])
  @@index([provider, model, effectiveFrom])
}

model FxRate {
  id               String   @id @default(uuid())
  rateDate         DateTime @db.Date
  usdIlsRate       Decimal  @db.Decimal(12, 6)
  source           String
  isManualOverride Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@unique([rateDate, source])
  @@index([rateDate, isManualOverride])
}

model ProcessingJob {
  id             String              @id @default(uuid())
  sessionId      String
  session        AnalyticsSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  type           ProcessingJobType
  status         ProcessingJobStatus @default(QUEUED)
  idempotencyKey String              @unique
  encryptedInput String
  encryptedResult String?
  progressStage  String?
  progress       Int                 @default(0)
  attempts       Int                 @default(0)
  errorMessage   String?
  queueEventId   String?
  startedAt      DateTime?
  completedAt    DateTime?
  expiresAt      DateTime
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([sessionId, status])
  @@index([status, createdAt])
  @@index([leadId, type])
  @@index([expiresAt])
}
